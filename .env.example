# Database (Neon / Supabase / local Postgres)
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/ai_usage?schema=public"

# Supabase: use Session pooler URI from dashboard (not direct db.*.supabase.co on IPv4 networks).
# Encode @ in password as %40. Example:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?schema=public&sslmode=require"

# API
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
INTERNAL_API_TOKEN=change-me-internal-token

# Dashboard (include https:// in production URLs)
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_INTERNAL_API_TOKEN=change-me-internal-token
INTERNAL_API_TOKEN=change-me-internal-token
REPORT_ACCESS_TOKEN=change-me-report-token

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ai-usage-reports
R2_PUBLIC_URL=https://cdn.yoursite.com

# Google Chat
GOOGLE_CHAT_WEBHOOK_URL=

# Live usage sync (Claude + Cursor)
ANTHROPIC_ADMIN_API_KEY=

# Cursor — pick ONE method:
# Personal / Pro: session cookie from cursor.com (DevTools → Cookies → WorkosCursorSessionToken)
CURSOR_SESSION_TOKEN=
CURSOR_TEAM_ID=0
CURSOR_USER_ID=
# Optional: display name shown on the Cursor report (email still comes from Cursor)
CURSOR_DISPLAY_NAME=

# Enterprise teams only: Team Admin API key from cursor.com/dashboard → API Keys → Team
CURSOR_ADMIN_API_KEY=
SYNC_ENABLED=true
SYNC_ON_START=true
SYNC_CRON=0 * * * *
SYNC_DAYS=30
CLEAR_SEED_ON_SYNC=true

# Screenshot worker
DASHBOARD_URL=http://localhost:3000
API_URL=http://localhost:4000
CRON_SCHEDULE=0 19 * * *
CRON_TIMEZONE=Asia/Kolkata
# Cursor report to Google Chat (Mon–Fri 7:30 PM IST when using local scheduler)
CURSOR_CRON_SCHEDULE=30 19 * * 1-5
SCREENSHOT_OUTPUT_PATH=./daily-report.png
CURSOR_SCREENSHOT_OUTPUT_PATH=./cursor-report.png
